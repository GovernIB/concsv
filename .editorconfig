root = true

[*]
indent_style = tab
indent_size = tab
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,ts,jsx,tsx,json}]
indent_style = space
indent_size = 4
tab_width = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 4
tab_width = 4

[*.md]
indent_style = space
indent_size = 4
tab_width = 4
