<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>ConCSV: API REST INTERNA</display-name>

    <context-param>
        <param-name>es.caib.concsv.commons.rest.supportedLocales</param-name>
        <param-value>ca,es</param-value>
    </context-param>

    <security-role>
        <role-name>CSV_REST</role-name>
    </security-role>
    <security-role>
        <role-name>CSV_COM</role-name>
    </security-role>

    <!-- Es treu la seguretat en l'API interna de CONCSV per problemes de rendiment en l'autenticació -->
    <!--
    <security-constraint>
        <display-name>API interna de CONCSV</display-name>
        <web-resource-collection>
            <url-pattern>/printable/*</url-pattern>
            <url-pattern>/original/*</url-pattern>
            <url-pattern>/enidoc/*</url-pattern>
            <url-pattern>/metadata/*</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>CSV_REST</role-name>
        </auth-constraint>
    </security-constraint>
    -->
    <security-constraint>
        <display-name>API integració COMANDA amb autenticació</display-name>
        <web-resource-collection>
            <url-pattern>/v1/salut/*</url-pattern>
            <url-pattern>/v1/estadistiques</url-pattern>
            <url-pattern>/v1/estadistiques/*</url-pattern>
            <url-pattern>/v1/logs</url-pattern>
            <url-pattern>/v1/logs/*</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>CSV_COM</role-name>
        </auth-constraint>
    </security-constraint>
    <security-constraint>
        <display-name>Sense autenticació</display-name>
        <web-resource-collection>
            <!-- -->
            <url-pattern>/printable/*</url-pattern>
            <url-pattern>/original/*</url-pattern>
            <url-pattern>/enidoc/*</url-pattern>
            <url-pattern>/metadata/*</url-pattern>
            <!-- -->
            <url-pattern>/v1/salut</url-pattern>
			<url-pattern>/v1/salutPerformance</url-pattern>
            <url-pattern>/swagger/*</url-pattern>
        </web-resource-collection>
    </security-constraint>
    <login-config>
        <auth-method>KEYCLOAK</auth-method>
        <realm-name>Govern de les Illes Balears</realm-name>
    </login-config>
	<!--  Si la seguridad esta activada, debe comentarse el siguente bloque security-constraint
	<security-constraint>
		<display-name>Unauthenticated</display-name>
		<web-resource-collection>
			<web-resource-name>Unauthenticated</web-resource-name>
			<url-pattern>/*</url-pattern>
		</web-resource-collection>
	</security-constraint>-->

</web-app>
